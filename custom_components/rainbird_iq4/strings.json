{
  "config": {
    "step": {
      "user": {
        "title": "RainBird IQ4",
        "description": "Sign in with your RainBird IQ4 cloud account.",
        "data": {
          "email": "Email",
          "password": "[%key:common::config_flow::data::password%]"
        },
        "data_description": {
          "email": "The email address for your RainBird IQ4 cloud account."
        }
      },
      "select_controller": {
        "title": "Select controller",
        "description": "Choose the controller to set up. Add the integration again for additional controllers.",
        "data": {
          "controller_id": "Controller"
        }
      },
      "reauth_confirm": {
        "title": "Re-authenticate",
        "description": "Please re-enter your RainBird IQ4 password.",
        "data": {
          "password": "[%key:common::config_flow::data::password%]"
        }
      }
    },
    "error": {
      "invalid_auth": "[%key:common::config_flow::error::invalid_auth%]",
      "cannot_connect": "[%key:common::config_flow::error::cannot_connect%]",
      "no_controllers": "No controllers found for this account.",
      "unknown": "[%key:common::config_flow::error::unknown%]"
    },
    "abort": {
      "already_configured": "[%key:common::config_flow::abort::already_configured_device%]",
      "reauth_successful": "[%key:common::config_flow::abort::reauth_successful%]"
    }
  },
  "entity": {
    "binary_sensor": {
      "connected": {
        "name": "Connected"
      },
